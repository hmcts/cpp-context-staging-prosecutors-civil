{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/civil/command/api/submit-material-with-submission-id.json",
  "type": "object",
  "properties": {
    "materialId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "caseUrn": {
      "type": "string",
      "maxLength": 36
    },
    "prosecutingAuthority": {
      "type": "string",
      "description": "Identifies the Prosecuting Organisation responsible for initiating the case. Valid CJS OU Code.",
      "maxLength": 7
    },
    "materialType": {
      "type": "string"
    },
    "defendantId": {
      "type": "string",
      "maxLength": 36
    },
    "submissionId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    }
  },
  "required": [
    "material",
    "caseUrn",
    "prosecutingAuthority",
    "materialType",
    "submissionId"
  ]
}
