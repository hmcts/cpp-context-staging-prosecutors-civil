{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/hearing-details.json",
  "type": "object",
  "properties": {
    "courtHearingLocation": {
      "type": "string",
      "description": "The OUCODE of the courthouse",
      "minLength": 1,
      "maxLength": 7
    },
    "dateOfHearing": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/date",
      "description": "The date of the hearing"
    },
    "timeOfHearing": {
      "type": "string",
      "description": "The actual start time of the hearing",
      "pattern": "^(2[0-3]|[01]?[0-9]):([0-5]?[0-9]):([0-5]?[0-9])$",
      "maxLength": 8
      },
    "hearingType": {
      "type": "string",
      "description": "Hearing type. Maps to court session types and is used as auto-listing criteria for hearing date range requests.",
      "maxLength": 10
    },
    "startDateRangeOfHearing": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/date",
      "description": "The date range (start) of the Court Hearing to be auto-allocated"
    },
    "endDateRangeOfHearing": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/date",
      "description": "The date range (end) of the Court Hearing to be auto-allocated"
    }
  },
  "required": [
    "courtHearingLocation"
  ]
}

